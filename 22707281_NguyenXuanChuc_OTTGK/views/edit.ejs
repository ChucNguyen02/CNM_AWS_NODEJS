<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa Sản Phẩm</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
            max-width: 500px;
            margin: auto;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
        }

        input[type="text"],
        input[type="number"],
        input[type="file"] {
            width: 100%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .btn {
            padding: 10px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            color: white;
        }

        .btn-submit {
            background-color: #ffc107;
            color: black;
        }

        .btn-cancel {
            background-color: #6c757d;
            text-decoration: none;
            display: inline-block;
        }

        .current-img {
            width: 150px;
            border-radius: 5px;
            margin-top: 10px;
            display: block;
        }

        .readonly-input {
            background-color: #e9ecef;
            cursor: not-allowed;
        }
    </style>
</head>

<body>

    <h2>Cập Nhật Sản Phẩm</h2>

    <form action="/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">

        <input type="hidden" name="old_image" value="<%= product.url_image %>">

        <div class="form-group">
            <label>Mã sản phẩm (ID):</label>
            <input type="text" name="id" value="<%= product.id %>" class="readonly-input" readonly>
        </div>

        <div class="form-group">
            <label>Tên sản phẩm:</label>
            <input type="text" name="name" value="<%= product.name %>" required>
        </div>

        <div class="form-group">
            <label>Giá (VNĐ):</label>
            <input type="number" name="price" value="<%= product.price %>" required min="0">
        </div>

        <div class="form-group">
            <label>Số lượng tồn kho:</label>
            <input type="number" name="unit_in_stock" value="<%= product.unit_in_stock %>" required min="0">
        </div>

        <div class="form-group">
            <label>Hình ảnh sản phẩm (Bỏ trống nếu không muốn đổi):</label>
            <input type="file" name="image" accept="image/*">

            <% if (product.url_image) { %>
                <small>Ảnh hiện tại:</small>
                <img src="<%= cloudFrontDomain %>/<%= product.url_image %>" class="current-img" alt="Ảnh hiện tại">
                <% } %>
        </div>

        <button type="submit" class="btn btn-submit">Cập Nhật</button>
        <a href="/" class="btn btn-cancel">Hủy Bỏ</a>
    </form>

</body>

</html>