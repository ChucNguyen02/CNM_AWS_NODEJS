<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết Sản Phẩm</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; display: flex; justify-content: center; }
        .card { border: 1px solid #ddd; border-radius: 8px; padding: 20px; max-width: 400px; text-align: center; box-shadow: 2px 2px 10px rgba(0,0,0,0.1); }
        .detail-img { width: 100%; max-height: 300px; object-fit: cover; border-radius: 5px; margin-bottom: 15px; }
        .info { text-align: left; margin-bottom: 15px; line-height: 1.6; }
        .btn-back { background-color: #007bff; color: white; padding: 10px 15px; text-decoration: none; border-radius: 4px; display: inline-block; }
    </style>
</head>
<body>

    <div class="card">
        <h2>Thông tin chi tiết</h2>
        
        <% if (product.url_image) { %>
            <img src="<%= cloudFrontDomain %>/<%= product.url_image %>" alt="<%= product.name %>" class="detail-img">
        <% } else { %>
            <div style="height: 200px; background: #eee; display: flex; align-items: center; justify-content: center; margin-bottom: 15px;">
                Không có ảnh
            </div>
        <% } %>

        <div class="info">
            <p><strong>Mã ID:</strong> <%= product.id %></p>
            <p><strong>Tên sản phẩm:</strong> <%= product.name %></p>
            <p><strong>Giá bán:</strong> <span style="color: red; font-weight: bold;"><%= product.price %> VNĐ</span></p>
            <p><strong>Số lượng tồn kho:</strong> <%= product.unit_in_stock %> sản phẩm</p>
        </div>

        <a href="/" class="btn-back">Quay lại danh sách</a>
    </div>

</body>
</html>